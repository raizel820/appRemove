// EURL LA SOURCE - Invoice Management App Schema (Updated)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// COMPANY SETTINGS (Expanded)
// ============================================
model Company {
  id           String  @id @default(cuid())
  name         String
  address      String?
  phoneNumbers String? // JSON array of phone numbers
  faxNumbers   String? // JSON array of fax numbers
  emails       String? // JSON array of emails

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Deprecated: Use activeCompanyProfile instead
  // French identifiers (kept for backward compatibility)
  nif      String? // Numéro d'Identification Fiscale (VAT number)
  nis      String? // Numéro d'Identification Statistique (corporate number)
  rib      String? // Relevé d'Identité Bancaire (bank account)
  rcn      String? // Registre du Commerce et des Sociétés (trade register)
  bankName String? // Bank name

  // Additional identifiers (kept for backward compatibility)
  fundCapital Float? // Capital de fond (share capital)

  // Activity descriptions for header template
  activityDescriptionAr String? // Activity description in Arabic
  activityDescriptionFr String? // Activity description in French

  // Logo
  activeLogoId        String? // ID of the active/default logo
  logos               CompanyLogo[] // All uploaded logos for this company
  currency            String        @default("EUR")
  defaultLanguage     String        @default("en") // en, ar, fr

  // Multiple Activity Profiles
  activeProfileId     String? // ID of the currently active profile
  activityProfiles    CompanyProfile[]
}

// ============================================
// COMPANY PROFILES (Multiple profiles for different activities)
// ============================================
model CompanyProfile {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Profile Number (user-defined, e.g., 1, 2, 3, etc.)
  profileNumber Int    @default(1)

  // Profile Name (e.g., "Manufacturing", "Trading", "Services")
  profileName  String

  // Business Identifiers (French)
  nif          String? // Numéro d'Identification Fiscale (VAT number)
  nis          String? // Numéro d'Identification Statistique (corporate number)
  rcn          String? // Registre du Commerce et des Sociétés (trade register)

  // Financial Information
  rib          String? // Relevé d'Identité Bancaire (bank account)
  bankName     String? // Bank name
  fundCapital  Float?  // Capital de fond (share capital)

  isActive     Boolean  @default(false) // Whether this is the active profile
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([companyId, profileNumber])
  @@index([companyId])
  @@index([companyId, isActive])
}

// ============================================
// COMPANY LOGOS (Multiple logos per company)
// ============================================
model CompanyLogo {
  id           String   @id @default(cuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  filename     String // Stored filename in public folder
  originalName String // Original uploaded filename
  fileType     String // e.g., image/jpeg, image/png
  fileSize     Int // File size in bytes
  isActive     Boolean  @default(false) // Whether this is the active/default logo
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([companyId])
  @@index([companyId, isActive])
}

// ============================================
// CUSTOMERS (Expanded with French fields)
// ============================================
model Customer {
  id        String @id @default(cuid())
  code      String @unique // Customer short code for file naming
  fullName  String // Full name for display and folder naming
  shortName String // Short name for file naming

  // Contact Information
  address String?
  city    String?
  country String?
  phone   String?
  email   String?

  // Business Identifiers
  nif String? // Numéro d'Identification Fiscale (VAT number)
  nis String? // Numéro d'Identification Statistique (corporate number)
  rib String? // Relevé d'Identité Bancaire (bank account)
  rcn String? // Registre du Commerce et des Sociétés (trade register)

  // Additional
  notes String?

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  orders    Order[]
  auditLogs AuditLog[]

  @@index([deletedAt])
  @@index([fullName])
  @@index([nif])
  @@index([nis])
  @@index([rib])
  @@index([rcn])
}

// ============================================
// MACHINE SPECIFICATIONS (Reusable templates)
// ============================================
model SpecTemplate {
  id          String  @id @default(cuid())
  name        String  @unique // e.g., "Standard", "Heavy Duty", "Custom"
  description String?
  category    String // e.g., "Capacity", "Power", "Dimensions", "Materials"
  fields      String // JSON array of available fields
  isActive    Boolean @default(true) // Template can be disabled

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  machineModels MachineModel[]
}

// ============================================
// SPECIFICATION DEFINITIONS (Individual specs with translations)
// ============================================
model SpecDefinition {
  id          String  @id @default(cuid())
  code        String  @unique // e.g., "RPM", "VOLTAGE", "CAPACITY"
  type        String  @default("text") // text, number, boolean, select
  unit        String? // e.g., "rpm", "V", "kg", "mm"

  // Translations in three languages
  labelFr     String? // French label
  labelEn     String? // English label
  labelAr     String? // Arabic label
  descriptionFr String? // French description
  descriptionEn String? // English description
  descriptionAr String? // Arabic description

  // Category for organization
  category    String? // e.g., "mechanical", "electrical", "physical"

  // Options for select type (JSON array)
  options     String? // JSON: ["Option 1", "Option 2", "Option 3"]

  // Validation rules
  required    Boolean @default(false)
  minValue    Float?
  maxValue    Float?
  pattern     String? // Regex pattern for validation

  // Status
  isActive    Boolean @default(true)
  sortOrder   Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  modelSpecs ModelSpec[]

  @@index([category])
  @@index([isActive])
  @@index([sortOrder])
}

// ============================================
// MODEL SPECS (Selected specs with values for each model)
// ============================================
model ModelSpec {
  id               String  @id @default(cuid())
  modelId          String
  specDefinitionId String
  value            String? // Stored as string, can be number, boolean, or text
  sortOrder        Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  model           MachineModel     @relation(fields: [modelId], references: [id], onDelete: Cascade)
  specDefinition  SpecDefinition   @relation(fields: [specDefinitionId], references: [id], onDelete: Cascade)

  @@unique([modelId, specDefinitionId])
  @@index([modelId])
  @@index([specDefinitionId])
  @@index([sortOrder])
}

// ============================================
// MACHINE FAMILIES (Categories)
// ============================================
model MachineFamily {
  id          String  @id @default(cuid())
  name        String
  description String?
  code        String  @unique // Family code (e.g., MZ)
  modelSpecs  Boolean @default(false) // Does this family use model specs templates?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  models MachineModel[]
}

// ============================================
// MACHINE MODELS (Products)
// ============================================
model MachineModel {
  id             String  @id @default(cuid())
  familyId       String
  name           String
  code           String  @unique // Model code (e.g., MZ100)
  description    String?
  basePrice      Float?
  currency       String  @default("EUR") // Model price currency
  specifications String? // JSON string of key-value specs (deprecated - use modelSpecTemplates)
  specTemplateId String? // Reference to reusable spec template

  // New structured spec fields (JSON). Nullable.
  // Use Prisma Json to store structured mechanical / electrical / physical specs
  mechanicalSpecs Json? // e.g. {ram: "x", speed: "y", bearings: {type: "..."}}
  electricalSpecs Json? // e.g. {voltage: "400V", current: "10A", power: "2kW"}
  physicalSpecs   Json? // e.g. {weightKg: 120, dimensions: {w: 800, h: 1200, d: 600}}

  // Manufacturing settings
  isManufactured Boolean @default(true) // true = generates serials, false = imported

  // Additional
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  family       MachineFamily @relation(fields: [familyId], references: [id])
  specTemplate SpecTemplate? @relation(fields: [specTemplateId], references: [id])
  modelSpecs   ModelSpec[]
  orderItems   OrderItem[]

  @@index([familyId])
}

// ============================================
// ORDER NUMBER STATES
// ============================================
enum OrderNumberState {
  USED // Number currently assigned to an active order
  RESERVED // Temporarily claimed for in-progress order/draft
  REUSABLE // Previously used and explicitly marked as reusable
  BLOCKED // Previously used and marked non-reusable
}

// ============================================
// ORDER NUMBERS (Authoritative ledger of all order numbers)
// ============================================
model OrderNumber {
  number     Int              @unique // The actual order number (e.g., 1, 2, 3, ...)
  state      OrderNumberState @default(RESERVED)
  reservedBy String? // Draft order ID or session token holding this reservation
  reservedAt DateTime? // When the number was reserved
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  notes      String? // Optional: origin info (e.g., original order id)

  // Relations
  orders Order[] // All orders that have used this number

  @@index([state])
  @@index([reservedBy])
  @@index([reservedAt])
}

// ============================================
// ORDER NUMBERS (Year-based numbering ledger)
// ============================================
model OrderNumbers {
  id         String           @id @default(cuid())
  year       Int // 2025, 2026, etc.
  seq        Int // Sequence within the year (1, 2, 3, ...)
  state      OrderNumberState @default(RESERVED) // RESERVED, USED, REUSABLE, BLOCKED
  reservedBy String? // Draft order ID or session token
  reservedAt DateTime? // When this number was reserved
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([year, seq])
  @@index([state])
  @@index([reservedBy])
  @@index([reservedAt])
  @@index([year, state])
}

// ============================================
// INVOICE NUMBERS (Year-based numbering ledger - independent from orders)
// ============================================
model InvoiceNumbers {
  id         String           @id @default(cuid())
  year       Int // 2025, 2026, etc.
  seq        Int // Sequence within the year (1, 2, 3, ...)
  state      OrderNumberState @default(RESERVED) // RESERVED, USED, REUSABLE, BLOCKED
  reservedBy String? // Draft invoice ID or session token
  reservedAt DateTime? // When this number was reserved
  orderId    String? // Optional link to order when finalized
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([year, seq])
  @@index([state])
  @@index([reservedBy])
  @@index([reservedAt])
  @@index([year, state])
  @@index([orderId])
}

// ============================================
// PROFORMA NUMBERS (Year-based numbering ledger - independent from orders)
// ============================================
model ProformaNumbers {
  id         String           @id @default(cuid())
  year       Int // 2025, 2026, etc.
  seq        Int // Sequence within the year (1, 2, 3, ...)
  state      OrderNumberState @default(RESERVED) // RESERVED, USED, REUSABLE, BLOCKED
  reservedBy String? // Draft proforma ID or session token
  reservedAt DateTime? // When this number was reserved
  orderId    String? // Optional link to order when finalized
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([year, seq])
  @@index([state])
  @@index([reservedBy])
  @@index([reservedAt])
  @@index([year, state])
  @@index([orderId])
}

// ============================================
// PURCHASE ORDER NUMBERS (Year-based numbering ledger - independent from orders)
// ============================================
model PurchaseOrderNumbers {
  id         String           @id @default(cuid())
  year       Int // 2025, 2026, etc.
  seq        Int // Sequence within the year (1, 2, 3, ...)
  state      OrderNumberState @default(RESERVED) // RESERVED, USED, REUSABLE, BLOCKED
  reservedBy String? // Draft purchase order ID or session token
  reservedAt DateTime? // When this number was reserved
  orderId    String? // Optional link to order when finalized
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([year, seq])
  @@index([state])
  @@index([reservedBy])
  @@index([reservedAt])
  @@index([year, state])
  @@index([orderId])
}

// ============================================
// DELIVERY NUMBERS (Year-based numbering ledger - independent from orders)
// ============================================
model DeliveryNumbers {
  id         String           @id @default(cuid())
  year       Int // 2025, 2026, etc.
  seq        Int // Sequence within the year (1, 2, 3, ...)
  state      OrderNumberState @default(RESERVED) // RESERVED, USED, REUSABLE, BLOCKED
  reservedBy String? // Draft delivery note ID or session token
  reservedAt DateTime? // When this number was reserved
  orderId    String? // Optional link to order when finalized
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([year, seq])
  @@index([state])
  @@index([reservedBy])
  @@index([reservedAt])
  @@index([year, state])
  @@index([orderId])
}

// ============================================
// DOCUMENT SPLITS (for splitting documents within an order)
// ============================================
model DocumentSplit {
  id            String   @id @default(cuid())
  orderId       String
  documentType  String   // 'invoice', 'proforma', 'purchase-order', 'delivery-note'
  splitIndex    Int      // 0, 1, 2, ...
  itemIds       String   // JSON array of item IDs
  number        String?  // The document number for this split (e.g., "INV-001/2026")
  sequence      Int?     // Sequence number for this split
  year          Int?     // Year for this split
  date          DateTime? // Date for this split
  status        String   @default("DRAFT") // DRAFT, RESERVED, ISSUED
  verificationToken String? // Verification token for this split

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, documentType, splitIndex])
  @@index([orderId])
  @@index([orderId, documentType])
}

// ============================================
// ORDER TYPES
// ============================================
enum OrderType {
  INVOICE
  PROFORMA
  DELIVERY_NOTE
  PURCHASE_ORDER
}

// ============================================
// ORDER STATUS
// ============================================
enum OrderStatus {
  DRAFT
  SENT
  PAID
  DELAYED
  CANCELLED
  PARTIALLY_PAID
  ACTIVE_ORDER
}

// ============================================
// ORDER ITEMS (machines/products in an order)
// ============================================
model OrderItem {
  id             String  @id @default(cuid())
  orderId        String
  modelId        String?
  description    String
  quantity       Int     @default(1)
  unitPrice      Float
  discount       Float   @default(0)
  totalPrice     Float
  serialNumbers  String? // JSON array of serial numbers for this item
  specifications String? // JSON specs specific to this order item (overrides model specs)

  // Customization
  isCustomized         Boolean @default(false) // Custom configuration
  customizationVersion Int? // v1, v2, etc.

  // Snapshot fields for machine model (stored at order creation)
  snapshotModel String? // JSON: Machine model data snapshot (name, code, family, isManufactured, etc.)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  model MachineModel? @relation(fields: [modelId], references: [id])

  @@index([orderId])
  @@index([modelId])
}

// ============================================
// SERIAL NUMBER COUNTER (for generating serial numbers)
// ============================================
model SerialNumberCounter {
  id          String   @id @default(cuid())
  year        Int      @unique // 2026
  lastCounter Int      @default(0) // Last used number
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================
// AUDIT LOG
// ============================================
enum AuditAction {
  CREATE
  UPDATE
  DELETE
  RESTORE
  PDF_GENERATED
  EMAIL_SENT
}

model AuditLog {
  id         String      @id @default(cuid())
  entityType String // Customer, Order, etc.
  entityId   String
  action     AuditAction
  userId     String? // Future: for multi-user
  changes    String? // JSON string of changes
  metadata   String? // JSON string of additional info
  customerId String?
  orderId    String?
  createdAt  DateTime    @default(now())

  customer Customer? @relation(fields: [customerId], references: [id])
  order    Order?    @relation(fields: [orderId], references: [id])

  @@index([entityType, entityId])
  @@index([customerId])
  @@index([orderId])
  @@index([createdAt])
}

// ============================================
// FTS5 VIRTUAL TABLES (for global search)
// ============================================
model CustomerSearch {
  id         String   @id @default(cuid())
  customerId String
  fullName   String
  shortName  String
  email      String
  phone      String
  nif        String?
  nis        String?
  rib        String?
  rcn        String?
  city       String?
  createdAt  DateTime @default(now())

  @@index([fullName])
  @@index([shortName])
  @@index([email])
  @@index([phone])
  @@index([nif])
  @@index([nis])
  @@index([rib])
  @@index([rcn])
}

model OrderSearch {
  id           String   @id @default(cuid())
  orderId      String
  type         String
  fullNumber   String
  customerName String
  notes        String?
  status       String
  total        Float
  currency     String
  date         DateTime
  createdAt    DateTime @default(now())

  @@index([fullNumber])
  @@index([customerName])
  @@index([status])
  @@index([type])
}

model SerialSearch {
  id           String   @id @default(cuid())
  orderItemId  String
  serialNumber String
  orderId      String
  description  String?
  createdAt    DateTime @default(now())

  @@index([serialNumber])
  @@index([orderId])
}

// ============================================
// PDF CONFIGURATION
// ============================================

enum PDFFontFamily {
  HELVETICA
  TIMES_ROMAN
  COURIER
  ARIAL
}

enum PDFDescriptionLanguage {
  FRENCH
  ENGLISH
}

model PDFConfiguration {
  id String @id @default(cuid())

  // Global Header Settings
  // Language for French/English description
  descriptionLanguage PDFDescriptionLanguage @default(ENGLISH)

  // Toggle which document types use this header
  useInInvoice       Boolean @default(true)
  useInProforma      Boolean @default(true)
  useInDeliveryNote  Boolean @default(true)
  useInPurchaseOrder Boolean @default(true)
  useInNameplate     Boolean @default(false)
  useInTechnicalFile Boolean @default(true)

  // Company profile fields to include (JSON)
  // These fields apply to both Arabic and French/English sides
  selectedCompanyFields String @default("{}")

  // Toggle which company info to include
  includeTelephone     Boolean @default(true)
  includeFax           Boolean @default(true)
  includeAddress       Boolean @default(true)
  includeEmail         Boolean @default(true)
  includeRcn           Boolean @default(true) // Trade register number
  includeNif           Boolean @default(true) // Tax identification number
  includeNis           Boolean @default(true) // Statistical number
  includeRib           Boolean @default(true) // Bank account number
  includeBankName      Boolean @default(true) // Bank agency
  includeCapitalSocial Boolean @default(true) // Capital social

  // Toggle which activity descriptions to include in header
  includeArabicDescription Boolean @default(true) // Show Arabic description
  includeFrenchDescription Boolean @default(true) // Show French description

  // Writing direction for each part (applies to entire column)
  leftPartDirection  String @default("LTR") // LTR or RTL for French/English column
  rightPartDirection String @default("RTL") // LTR or RTL for Arabic column

  // Global line spacing (for header fields)
  headerLineSpacing Float @default(1)

  // Company name styling
  companyNameFontFamily  PDFFontFamily @default(HELVETICA)
  companyNameFontSize    Int           @default(24)
  companyNameTextColor   String        @default("#000000")
  companyNameLineSpacing Float         @default(1)

  // Company description styling
  descriptionFontFamily  PDFFontFamily @default(HELVETICA)
  descriptionFontSize    Int           @default(12)
  descriptionTextColor   String        @default("#000000")
  descriptionLineSpacing Float         @default(1)

  // Logo settings
  logoScaling Float @default(1.5) // Scale factor (1.0 = 100%)
  logoOffsetX Int   @default(0) // Horizontal offset in pixels (negative = left, positive = right)
  logoOffsetY Int   @default(25) // Vertical offset in pixels (negative = up, positive = down)

  // Label font settings (for "Telephone:", "Fax:", etc.)
  labelFontFamily  PDFFontFamily @default(HELVETICA)
  labelFontSize    Int           @default(12)
  labelTextColor   String        @default("#000000")
  labelLineSpacing Float         @default(0.5)

  // Data font settings (for actual values like phone numbers, addresses)
  dataFontFamily  PDFFontFamily @default(HELVETICA)
  dataFontSize    Int           @default(12)
  dataTextColor   String        @default("#000000")
  dataLineSpacing Float         @default(0.5)

  // =====================
  // INVOICE SETTINGS
  // =====================

  // Invoice Top Body Part (Title, Client Info, Date)
  invoiceTopBodyDirection String @default("LTR") // LTR or RTL for top body section

  // Title settings
  invoiceTitlePosition      String        @default("center") // left, center, right
  invoiceTitleFontFamily    PDFFontFamily @default(HELVETICA)
  invoiceTitleFontSize      Int           @default(16)
  invoiceTitleTextColor     String        @default("#000000")
  invoiceTitleLineSpacing   Float         @default(0.5)
  invoiceTitleLetterSpacing Float         @default(0.0)
  invoiceTitleBold          Boolean       @default(true)
  invoiceTitleUnderline     Boolean       @default(false)

  // Customer info settings
  // Customer info position
  invoiceClientInfoPosition       String        @default("left") // left, center, right
  invoiceClientLabelText          String        @default("Client")
  // Customer info settings - Label
  invoiceClientLabelFontFamily    PDFFontFamily @default(HELVETICA)
  invoiceClientLabelFontSize      Int           @default(12)
  invoiceClientLabelTextColor     String        @default("#000000")
  invoiceClientLabelLineSpacing   Float         @default(0.5)
  invoiceClientLabelLetterSpacing Float         @default(0.0)
  invoiceClientLabelBold          Boolean       @default(true)
  invoiceClientLabelUnderline     Boolean       @default(false)

  // Customer info settings - Value
  invoiceClientValueFontFamily    PDFFontFamily @default(HELVETICA)
  invoiceClientValueFontSize      Int           @default(12)
  invoiceClientValueTextColor     String        @default("#000000")
  invoiceClientValueLineSpacing   Float         @default(0.5)
  invoiceClientValueLetterSpacing Float         @default(0.0)
  invoiceClientValueBold          Boolean       @default(false)
  invoiceClientValueUnderline     Boolean       @default(false)

  // Date/location settings
  invoiceDatePosition          String        @default("right") // left, center, right
  invoiceLocationDateLabelText String        @default("M'sila le") // Configurable label
  invoiceDateFontFamily        PDFFontFamily @default(HELVETICA)
  invoiceDateFontSize          Int           @default(12)
  invoiceDateTextColor         String        @default("#000000")
  invoiceDateLineSpacing       Float         @default(0.5)
  invoiceDateLetterSpacing     Float         @default(0.0)
  invoiceDateBold              Boolean       @default(false)
  invoiceDateUnderline         Boolean       @default(false)

  // Invoice Items Table
  invoiceTableTextAlignment String @default("left") // left, center, right
  invoiceTableDirection     String @default("LTR") // LTR or RTL for items table

  // Table labels (header row) settings
  invoiceTableLabelFontFamily    PDFFontFamily @default(HELVETICA)
  invoiceTableLabelFontSize      Int           @default(11)
  invoiceTableLabelTextColor     String        @default("#000000")
  invoiceTableLabelLineSpacing   Float         @default(1)
  invoiceTableLabelLetterSpacing Float         @default(0.0)
  invoiceTableLabelBold          Boolean       @default(true)
  invoiceTableLabelUnderline     Boolean       @default(false)

  // Table values (rest of table) settings
  invoiceTableValueFontFamily    PDFFontFamily @default(HELVETICA)
  invoiceTableValueFontSize      Int           @default(11)
  invoiceTableValueTextColor     String        @default("#000000")
  invoiceTableValueLineSpacing   Float         @default(1)
  invoiceTableValueLetterSpacing Float         @default(0.0)
  invoiceTableValueBold          Boolean       @default(false)
  invoiceTableValueUnderline     Boolean       @default(false)

  invoiceEmptyRows Int @default(8) // Number of empty rows to show

  // Items Table Max Height Settings
  invoiceSinglePageTableMaxHeight Int @default(297) // Max height of items table on single page (mm) - no height limit
  invoiceLastPageTableMaxHeight   Int @default(150) // Max height of items table on last page (mm) - page with summary + terms
  invoiceOtherPagesTableMaxHeight Int @default(180) // Max height of items table on other pages (mm) - pages without summary + terms
  invoiceFirstPageTableMaxHeight  Int @default(180) // Max height of items table on first page (mm) - with header and customer info

  // Column-specific settings for items table
  // Column 1: N° (Number)
  invoiceColNumberWidth   Float @default(5) // Column width in mm
  invoiceColNumberPadding Float @default(2) // Cell padding in mm

  // Column 2: Item family
  invoiceColFamilyWidth   Float @default(39.69) // Column width in mm (150px)
  invoiceColFamilyPadding Float @default(5.61) // Cell padding in mm (2.12mm * 2.65)

  // Column 3: Model
  invoiceColModelWidth   Float @default(39.69) // Column width in mm (150px)
  invoiceColModelPadding Float @default(5.61) // Cell padding in mm (2.12mm * 2.65)

  // Column 4: Brand
  invoiceColBrandWidth   Float @default(20) // Column width in mm
  invoiceColBrandPadding Float @default(5.61) // Cell padding in mm (2.12mm * 2.65)

  // Column 5: Quantity
  invoiceColQuantityWidth   Float @default(21.17) // Column width in mm (80px)
