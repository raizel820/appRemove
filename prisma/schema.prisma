// ============================================
// FILE TYPES (documents attached to orders)
// ============================================
enum FileType {
  INVOICE
  PROFORMA
  PURCHASE_ORDER
  DELIVERY_NOTE
  TECHNICAL_FILE
  NAMEPLATE
}

// ============================================
// FILE STATUS
// ============================================
enum FileStatus {
  DRAFT
  READY
  ERROR
}

// ============================================
// FILE SEQUENCE (per file type + year)
// ============================================
model FileSequence {
  id        String   @id @default(cuid())
  fileType  FileType
  year      Int
  sequence  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([fileType, year])
  @@index([fileType, year])
}

// ============================================
// FILE REVISIONS (versioning for edited files)
// ============================================
model FileRevision {
  id              String   @id @default(cuid())
  fileId          String
  revisionNumber  Int
  pdfPath         String
  templateVersion Json // Snapshot of template used
  changes         String? // JSON description of changes
  createdBy       String?
  createdAt       DateTime @default(now())

  file File @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@unique([fileId, revisionNumber])
  @@index([fileId])
}

// ============================================
// FILES (documents: invoice, proforma, PO, etc.)
// ============================================
model File {
  id              String     @id @default(cuid())
  orderId         String
  fileType        FileType
  numberYear      Int
  numberSequence  Int
  fullNumber      String
  fileDate        DateTime
  status          FileStatus @default(DRAFT)
  pdfPath         String?
  templateVersion Json // Snapshot of template version used
  notes           String?
  deletedAt       DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  order     Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  revisions FileRevision[]

  @@unique([numberYear, numberSequence, fileType, deletedAt])
  @@index([orderId])
  @@index([fileType])
  @@index([numberYear, numberSequence])
  @@index([deletedAt])
}

// ============================================
// ORDERS
// ============================================
model Order {
  id                 String      @id @default(cuid())
  type               OrderType
  orderNumber        Int? // Foreign key reference to OrderNumber.number (nullable until committed)
  numberYear         Int // 2026
  numberSequence     Int // 3 (for 003/2026)
  fullNumber         String // Computed: 003/2026
  customerId         String
  customerName       String // Denormalized for PDF
  date               DateTime
  dueDate            DateTime?
  status             OrderStatus @default(DRAFT)
  currency           String      @default("EUR")
  subtotal           Float       @default(0)
  taxRate            Float       @default(0)
  taxAmount          Float       @default(0)
  total              Float       @default(0)
  notes              String?
  pdfPath            String? // Path to generated PDF
  documentLanguage   String      @default("fr") // ar, en, fr for document body
  activityProfileId   String? // ID of the selected activity profile for this order
  payments           String? // JSON array of payment records
  deletedAt          DateTime?
  numberReuseAllowed Boolean     @default(false) // User choice when deleting: allow number reuse

  // Split document tracking
  parentId           String? // If this is a split, points to the original order ID
  splitOfDocumentType String? // Which document type was split (invoice, proforma, purchase-order, delivery-note)
  splitIndex         Int? // Which split this is (1, 2, 3, etc.)

  // Invoice fields (independent numbering)
  invoiceNumber     Int? // Foreign key reference to InvoiceNumbers
  invoiceYear       Int? // Invoice year
  invoiceSequence   Int? // Invoice sequence number
  invoiceFullNumber String? // Computed: INV-001/2026
  invoiceDate       DateTime? // Invoice date (can be different from order date)
  invoiceStatus     String? // Invoice status: DRAFT, ISSUED, PAID, CANCELLED

  // Proforma fields (independent numbering)
  proformaNumber     Int? // Foreign key reference to ProformaNumbers
  proformaYear       Int? // Proforma year
  proformaSequence   Int? // Proforma sequence number
  proformaFullNumber String? // Computed: PRO-001/2026
  proformaDate       DateTime? // Proforma date (can be different from order date)
  proformaStatus     String? // Proforma status: DRAFT, ISSUED, CANCELLED

  // Purchase Order fields (independent numbering)
  purchaseOrderNumber     Int? // Foreign key reference to PurchaseOrderNumbers
  purchaseOrderYear       Int? // Purchase Order year
  purchaseOrderSequence   Int? // Purchase Order sequence number
  purchaseOrderFullNumber String? // Computed: PO-001/2026
  purchaseOrderDate       DateTime? // Purchase Order date (can be different from order date)
  purchaseOrderStatus     String? // Purchase Order status: DRAFT, ISSUED, CANCELLED

  // Snapshot fields for invoice/proforma/purchase order preview (stored at order creation)
  snapshotCompany   String? // JSON: Company data snapshot
  snapshotCustomer  String? // JSON: Customer data snapshot  
  snapshotPdfConfig String? // JSON: PDF configuration snapshot

  // Verification token for QR code
  invoiceVerificationToken       String? // Verification token linked to invoice
  proformaVerificationToken      String? // Verification token linked to proforma
  purchaseOrderVerificationToken String? // Verification token linked to purchase order

  // Delivery Note fields (independent numbering)
  deliveryNoteNumber            Int? // Foreign key reference to DeliveryNumbers
  deliveryNoteYear              Int? // Delivery Note year
  deliveryNoteSequence          Int? // Delivery Note sequence number
  deliveryNoteFullNumber        String? // Computed: DN-001/2026
  deliveryNoteDate              DateTime? // Delivery Note date (can be different from order date)
  deliveryNoteStatus            String? // Delivery Note status: DRAFT, ISSUED, CANCELLED
  deliveryNoteVerificationToken String? // Verification token linked to delivery note

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer  Customer        @relation(fields: [customerId], references: [id])
  items     OrderItem[]
  auditLogs AuditLog[]
  files     File[]
  numberRef OrderNumber?    @relation(fields: [orderNumber], references: [number])
  splits    DocumentSplit[] // All document splits for this order

  @@unique([orderNumber, deletedAt]) // Ensure no two active orders share the same number
  @@unique([numberYear, numberSequence, deletedAt])
  @@index([orderNumber])
  @@index([numberYear, numberSequence])
  @@index([customerId])
  @@index([status])
  @@index([deletedAt])
  @@index([parentId]) // Index for finding split documents
  @@index([parentId, splitOfDocumentType]) // Composite index for split documents
  @@index([invoiceNumber])
  @@index([invoiceYear, invoiceSequence])
  @@index([invoiceStatus])
  @@index([invoiceVerificationToken])
  @@index([proformaNumber])
  @@index([proformaYear, proformaSequence])
  @@index([proformaStatus])
  @@index([proformaVerificationToken])
  @@index([purchaseOrderNumber])
  @@index([purchaseOrderYear, purchaseOrderSequence])
  @@index([purchaseOrderStatus])
  @@index([purchaseOrderVerificationToken])
  @@index([deliveryNoteNumber])
  @@index([deliveryNoteYear, deliveryNoteSequence])
  @@index([deliveryNoteStatus])
  @@index([deliveryNoteVerificationToken])
}

// ============================================
// QR CODE SETTINGS
// ============================================
model QRCodeSettings {
  id        String   @id @default(cuid())
  config    String // JSON string of QRCodeConfig
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// VERIFICATION TOKENS
// ============================================
model VerificationToken {
  id         String   @id @default(cuid())
  token      String   @unique // The HMAC verification token
  qrJsonData String // The full JSON data that was used to generate the QR code
  label      String? // Optional label (e.g., "test" for test tokens)
  createdAt  DateTime @default(now())

  @@index([token])
  @@index([label])
}

// ============================================
// BACKUP SYSTEM
// ============================================
model Backup {
  id           String    @id @default(cuid())
  filename     String    // Generated filename for the backup file
  description  String?   // User-provided description
  fileSize     Int       // File size in bytes
  dataTypes    String    // JSON array of included data types
  dateFrom     DateTime? // Start date for filtered backup (optional)
  dateTo       DateTime? // End date for filtered backup (optional)
  status       String    @default("completed") // completed, failed, partial
  errorMessage String?   // Error message if failed
  recordCount  Int       @default(0) // Total number of records backed up
  createdBy    String?   // User who created backup (for future use)
  createdAt    DateTime  @default(now())

  @@index([createdAt])
  @@index([status])
}
